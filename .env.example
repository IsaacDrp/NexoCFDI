# ── PostgreSQL ────────────────────────────────────────────────
DB_NAME=nexocfdi
DB_USERNAME=nexo
DB_PASSWORD=nexo_secret_change_me
DB_PORT=5432

# ── Azure App Registrations ───────────────────────────────────
# NexoCfdi-login: app de login (MSAL frontend) — audience del JWT
AZURE_LOGIN_CLIENT_ID=your-login-app-client-id
# NexoCfdi-mail: app de correo (IMAP/SMTP OAuth)
AZURE_CLIENT_ID=your-mail-app-client-id
AZURE_CLIENT_SECRET=your-mail-app-client-secret
AZURE_REDIRECT_URI=http://localhost:4200/oauth/callback

# ── AES-256-GCM key (base64 de 32 bytes) ─────────────────────
# Genera con: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ── App ───────────────────────────────────────────────────────
SERVER_PORT=8080
SHOW_SQL=false
POLLING_INTERVAL_MINUTES=15
